// مرحبا بك في هافنيكس! 🇸🇩
// اكتب كود هافنيكس هنا واضغط F5 للتشغيل

$الاسم = "عثمان";
$العمر = 18;

قول ليهو("مرحبا يا $الاسم!");
قول ليهو("عمرك $العمر سنة");

لو ($العمر >= 18) {
    قول ليهو("انت كبير 💪");
}

$فواكه = ["تفاح", "موز", "برتقال"];
لكل $فاكهة في $فواكه {
    قول ليهو("فاكهة: $فاكهة");
}

دالة مرحبا(الاسم) {
    قول ليهو("اهلا يا $الاسم!");
}
جيب لي مرحبا("احمد");
