RewriteEngine On

# Auto-detect base directory
# If installed at localhost/havnix/ → RewriteBase /havnix/website/
# If installed at root → RewriteBase /
# Adjust this line to match your installation path:
RewriteBase /

# Redirect to HTTPS (uncomment for production)
# RewriteCond %{HTTPS} off
# RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# Allow access to real files and directories
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Route everything through index.php
RewriteRule ^(.*)$ index.php?slug=$1 [QSA,L]
